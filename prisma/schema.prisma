generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String?
  image       String?
  headline    String?
  bio         String?
  location    String?
  website     String?
  github      String?
  linkedin    String?
  twitter     String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills         Skill[]
  projects       Project[]
  certificates   Certificate[]
  experiences    Experience[]
  careerTargets  CareerTarget[]
  learningEvents LearningEvent[]
  resumeFiles    ResumeFile[]
}

model Skill {
  id                 String         @id @default(cuid())
  name               String
  category           String         @default("Other")
  proficiency        Int            @default(50)
  verification       String         @default("self_reported")
  verificationSource String?
  confidence         Float          @default(0.5)
  lastSeen           DateTime       @default(now())
  userId             String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentRelations SkillEdge[]    @relation("SkillEdgeFrom")
  childRelations  SkillEdge[]    @relation("SkillEdgeTo")
  projects        ProjectSkill[]

  // Embedding stored as JSON string for local SQLite dev; use pgvector column in production
  embedding       String?
}

model SkillEdge {
  id           String   @id @default(cuid())
  fromId       String   @map("from_id")
  toId         String   @map("to_id")
  relationType String   @default("related_to") @map("relation_type")
  weight       Float    @default(1.0)
  createdAt    DateTime @default(now())

  fromSkill Skill @relation("SkillEdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toSkill   Skill @relation("SkillEdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relationType])
  @@map("skill_edges")
}

model Project {
  id            String    @id @default(cuid())
  name          String
  description   String?
  technologies  String    @default("[]")
  architecture  String?
  complexity    String    @default("medium")
  difficulty    Int       @default(50)
  documentation String?
  testing       String?
  githubUrl     String?
  liveUrl       String?
  startDate     DateTime?
  endDate       DateTime?
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills  ProjectSkill[]
}

model ProjectSkill {
  id        String  @id @default(cuid())
  projectId String
  skillId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
}

model Certificate {
  id              String    @id @default(cuid())
  title           String
  issuingOrg      String?
  completionDate  DateTime?
  skills          String    @default("[]")
  imageUrl        String?
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String    @id @default(cuid())
  title       String
  company     String?
  startDate   DateTime
  endDate     DateTime?
  description String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerTarget {
  id           String    @id @default(cuid())
  role         String
  company      String?
  deadline     DateTime?
  targetSkills String    @default("[]")
  matchScore   Float?
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningEvent {
  id          String   @id @default(cuid())
  type        String   @default("skill_added")
  title       String
  description String?
  date        DateTime
  metadata    String?
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeFile {
  id        String   @id @default(cuid())
  filename  String
  fileUrl   String?
  content   String?
  skills    String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}